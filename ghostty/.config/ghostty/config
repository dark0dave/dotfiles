# The syntax is "key = value". The whitespace around the
# equals doesn't matter.
background = 000000
foreground = ffffff

# https://ghostty.org/docs/config/keybind/reference
keybind = shift+ctrl+w=close_surface
keybind = shift+ctrl+z=toggle_split_zoom
keybind = shift+ctrl+'=new_split:right
keybind = shift+ctrl+@=new_split:down

font-family = JetBrainsMono Nerd Font
font-size = 20
scrollback-limit = 100000000
scrollbar = system

