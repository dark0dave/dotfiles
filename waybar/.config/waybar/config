  "custom/playerctl": {
    "format": "{icon} {0}",
    "return-type": "json",
    "hide-empty-text": false,
    "max-length": 25,
    "exec": "playerctl -a metadata --format '{\"text\": \"{{markup_escape(title)}}\", \"tooltip\": \"{{playerName}}:{{markup_escape(title)}}\", \"alt\": \"{{status}}\", \"class\": \"{{status}}\"}'",
